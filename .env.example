# betabot — command-only Matrix/Tchap bot.
# It only handles slash commands; it does NOT chat in natural language.

# Data directory — where the crypto store and Matrix session live (default ./data).
DATA_DIR=./data

# Matrix
MATRIX_HOMESERVER=https://matrix.example.org
MATRIX_USER=@betabot:example.org
# IMPORTANT: get this token from a `curl` login (m.login.password), NOT from the
# Tchap/Element web client — a browser token shares a device whose E2E is managed
# by the web client, which breaks the bot's encryption ("Déchiffrement en cours…").
# A curl login mints a fresh dedicated device the bot alone owns. See README → "Getting the access token".
MATRIX_ACCESS_TOKEN=mct_...
# MATRIX_PASSWORD=...   # alternative: the bot logs in itself at startup

# Restrict the bot to specific rooms (comma-separated room IDs).
# Leave empty to allow all rooms (default). Room IDs look like !abc123:agent.xxx.tchap.gouv.fr
# MATRIX_ALLOWED_ROOMS=!roomid1:agent.dinum.tchap.gouv.fr,!roomid2:agent.dinum.tchap.gouv.fr

# Rooms where slash commands (/help, ...) are allowed (subset of allowed rooms).
# Empty = allowed everywhere the bot responds. Set to restrict to admin/dev rooms.
# When refused, the bot replies politely and points to the rooms where the command works.
# MATRIX_COMMAND_ROOMS=!adminroom:agent.dinum.tchap.gouv.fr
# Optional human-readable label shown in the refusal message instead of the cryptic room ID.
# MATRIX_COMMAND_ROOMS_LABEL=Salon Admin betabot

# Contact shown in the generic reply when someone DMs or @mentions the bot outside a command.
# MATRIX_CONTACT=beta-bot@beta.gouv.fr

# Rooms where the DiMail mailing list commands (/emails) are exposed (subset of allowed rooms).
# In rooms not listed here, /emails is unavailable. Leave empty to disable DiMail entirely.
# MATRIX_DIMAIL_ROOMS=!adminroom:agent.dinum.tchap.gouv.fr

# Matrix user IDs allowed to use admin commands like /historique, /salon role (comma-separated).
# Empty = nobody can use admin-only commands.
# MATRIX_ADMIN_USERS=@admin1:agent.dinum.tchap.gouv.fr,@admin2:agent.dinum.tchap.gouv.fr

# Space the bot is allowed to manage rooms in, via the /salon command (create/delete).
# The bot must have power level >= the space's m.space.child requirement (usually 100).
# Empty = the /salon command is disabled.
# MATRIX_MANAGED_SPACE=!spaceid:agent.dinum.tchap.gouv.fr

# DiMail API (mailing lists / aliases) — backs the /emails command.
DIMAIL_URL=https://api.XXXX.dimail1.numerique.gouv.fr
DIMAIL_USER=
DIMAIL_PASSWORD=
DIMAIL_DOMAIN=
# Optional: pre-existing Bearer token. If empty, scripts will login with DIMAIL_USER/PASSWORD.
# DIMAIL_TOKEN=
